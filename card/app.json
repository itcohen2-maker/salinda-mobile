{
  "expo": {
    "name": "Salinda / סלינדה",
    "slug": "salinda-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-launch-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121118"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cardgame.app",
      "jsEngine": "hermes",
      "userInterfaceStyle": "light",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "splash": {
        "image": "./assets/splash-launch-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#121118"
      }
    },
    "android": {
      "package": "com.salinda.game",
      "jsEngine": "hermes",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Salinda / סלינדה",
      "shortName": "סלינדה",
      "dir": "rtl",
      "display": "standalone",
      "backgroundColor": "#111827",
      "themeColor": "#111827",
      "barStyle": "default",
      "splash": {
        "image": "./assets/splash-launch-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#121118"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f6cd3cc8-5684-43de-bf3b-98b137c8d1a9",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "eas": {
        "projectId": "f6cd3cc8-5684-43de-bf3b-98b137c8d1a9"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#121118",
          "image": "./assets/splash-launch-logo.png",
          "imageWidth": 320
        }
      ],
      "expo-system-ui",
      "expo-localization",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "YOUR_ORG_SLUG",
          "project": "YOUR_PROJECT_SLUG"
        }
      ]
    ]
  }
}
