# Copy to .env for local builds. EAS production uses eas.json env.
#
# --- שרת במחשב שלך (הכי נוח לנסות) ---
# 1. npm run server:dev
# 2. EXPO_PUBLIC_LOCAL_SOCKET_SERVER=1  (בפיתוח בלבד — מתעלם מ-EXPO_PUBLIC_SERVER_URL למשחק מקוון)
# 3. Expo Go על אותה Wi‑Fi — יתחבר ל-IP של המחשב אוטומטית (כמו Metro).
# בלי הדגל: או תרוקן EXPO_PUBLIC_SERVER_URL או השאר רק את ה-URL לענן.
#
# --- ענן (לפרודקשן / בדיקות מרוחקות) ---
EXPO_PUBLIC_LOCAL_SOCKET_SERVER=0
# 1 = נעול בחירת שלבי תרגול A–H במסך מתקדמים (מיועד לרכישה / מנוי בעתיד)
EXPO_PUBLIC_LOCK_ADVANCED_STAGES=0
EXPO_PUBLIC_SERVER_URL=https://lolos-mobile.onrender.com
# Public Expo Web build used in invite links.
EXPO_PUBLIC_WEB_APP_URL=https://salinda-mobile.vercel.app
